NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Normal localhost path: `pnpm abi:sync` writes generated localhost addresses for the app.
# These values are only used when deployments/localhost.json was missing during `pnpm abi:sync`.
# If neither generated nor env fallback addresses exist, the app stays on the safe zero-address fallback.
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_POLICYVAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOCKUSDC_ADDRESS=0x0000000000000000000000000000000000000000
