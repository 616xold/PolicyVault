# Contracts / scripts
LOCAL_RPC_URL=http://127.0.0.1:8545
SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=

# App-facing values
# Normal localhost path: run `pnpm abi:sync` and let the app read generated localhost addresses.
# These NEXT_PUBLIC_* address values are only a fallback when deployments/localhost.json was
# missing during `pnpm abi:sync`; otherwise the app stays on a safe zero-address fallback.
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_POLICYVAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOCKUSDC_ADDRESS=0x0000000000000000000000000000000000000000
